# third_party/libboundscheck.BUILD
cc_library(
    name = "boundscheck",
    srcs = glob([
        "src/**/*.c",
        "src/**/*.cpp",
    ]),
    hdrs = glob([
        "include/**/*.h",
        "src/**/*.h",
        "**/*.inl",
    ]),
    includes = ["include"],
    linkstatic = True,
    alwayslink = True,
    visibility = ["//visibility:public"],
)

cc_library(
    name = "boundscheck_headers",
    hdrs = glob([
        "include/**/*.h",
    ]),
    includes = ["include"],
    visibility = ["//visibility:public"],
)
