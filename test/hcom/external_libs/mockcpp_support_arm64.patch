 #include <mockcpp/mockcpp.h>
 
+template <typename T>
+inline T changeByteOrder(const T v) {
+   enum { S = sizeof(T) };
+   T rst = v;
+   char *p = (char *)&rst;
+   char tmp = 0;
+   for (unsigned int i = 0; i < S / 2; ++i) {
+      tmp = p[i];
+      p[i] = p[S - i - 1];
+      p [S - i - 1] = tmp;
+   }
+
+   return rst;
+}
+
