+namespace Details {
+  template<typename Method>
+  void *methodToAddr(Method m)
+  {
+    union
+    {
+      void *addr_;
+      Method m_;
+    };
+
+    m_ = m;
+    return addr_;
+  }
+}  // namespace Details
+
 MOCKCPP_NS_END
 
 #endif
